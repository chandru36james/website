rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Reusable auth helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is authenticated and verified
    function isUserVerified() {
      return isSignedIn();
    }

    // Reusable check for administrative roles (Super Admin or Manager)
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin" ||
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Manager";
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin");
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Customers Collection
    match /customers/{customerId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Loans Collection & Subcollections
    match /loans/{loanId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();

      // Schedules is a subcollection under loans
      match /schedules/{scheduleId} {
        allow read: if isUserVerified();
        allow create, update: if isUserVerified();
        allow delete: if isUserVerified() && isAdmin();
      }
    }

    // Payments Collection (root collection)
    match /payments/{paymentId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Ledger Collection
    match /ledgers/{ledgerId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Collateral Collection
    match /collaterals/{collateralId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Cash Book Collection
    match /cashBooks/{cashBookId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Audit Logs Collection
    match /auditLogs/{auditLogId} {
      allow read: if isUserVerified();
      allow create: if isUserVerified();
      allow update, delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Finance Rules Collection
    match /financeRules/{ruleId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Guarantors Collection
    match /guarantors/{guarantorId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Documents Collection (root collection)
    match /documents/{documentId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Expenses Collection (root collection)
    match /expenses/{expenseId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Expense Categories Collection (root collection)
    match /expenseCategories/{categoryId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Notifications Collection (root collection)
    match /notifications/{notificationId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Agent Visits Collection (root collection)
    match /agentVisits/{visitId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Visits Collection (root collection)
    match /visits/{visitId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }

    // Settlements Collection (root collection)
    match /settlements/{settlementId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && isAdmin();
    }
  }
}
