rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Reusable auth helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is authenticated and verified
    function isUserVerified() {
      return isSignedIn();
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin");
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Customers Collection
    match /customers/{customerId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Loans Collection & Subcollections
    match /loans/{loanId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";

      match /schedules/{scheduleId} {
        allow read: if isUserVerified();
        allow create, update: if isUserVerified();
        allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
      }

      match /payments/{paymentId} {
        allow read: if isUserVerified();
        allow create, update: if isUserVerified();
        allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
      }
    }

    // Ledger Collection
    match /ledgers/{ledgerId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Collateral Collection
    match /collaterals/{collateralId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Cash Book Collection
    match /cashBooks/{cashBookId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Audit Logs Collection
    match /auditLogs/{auditLogId} {
      allow read: if isUserVerified();
      allow create: if isUserVerified();
      allow update, delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Finance Rules Collection
    match /financeRules/{ruleId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }

    // Guarantors Collection
    match /guarantors/{guarantorId} {
      allow read: if isUserVerified();
      allow create, update: if isUserVerified();
      allow delete: if isUserVerified() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "Super Admin";
    }
  }
}
